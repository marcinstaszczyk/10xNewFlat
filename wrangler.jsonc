{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "10x-new-flat",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"compatibility_date": "2026-05-08",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"assets": {
		"binding": "ASSETS",
		"directory": "./dist",
		"not_found_handling": "404-page",
	},
	"observability": {
		"enabled": true,
	},
	"kv_namespaces": [
		{
			"binding": "SESSION",
			"id": "1691ce534e214db6b4b84f18f4478b33"
		}
	],
}